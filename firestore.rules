rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is the specific admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "hmsolyman33@gmail.com";
    }

    // Orders: Public can create, Admin can do everything
    match /orders/{orderId} {
      allow create: if true; // Allow anyone to place an order
      allow read, update, delete: if isAdmin();
    }

    // Inventory: Admin only
    match /inventory/{itemId} {
      allow read, write: if isAdmin();
    }

    // Pixel Config: Admin only
    match /pixelConfig/{configId} {
      allow read: if true; // App needs to read pixel ID
      allow write: if isAdmin();
    }
  }
}
